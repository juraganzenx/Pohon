--DESTROY FRUIT AND PLANT PROJECT
local Gardens = workspace:WaitForChild("Gardens")
local DroppedItems = workspace:WaitForChild("DroppedItems")

while true do

    -- DESTROY PLANTS / FRUITS
    for _, Plot in ipairs(Gardens:GetChildren()) do
        local Plants = Plot:FindFirstChild("Plants")

        if Plants then
            for _, Plant in ipairs(Plants:GetChildren()) do

                -- Destroy Part/MeshPart pada Plant
                -- kecuali Fruits dan FruitSpawnLocations
                for _, Obj in ipairs(Plant:GetDescendants()) do
                    if (Obj:IsA("Part") or Obj:IsA("MeshPart"))
                        and not Obj:FindFirstAncestor("Fruits")
                        and not Obj:FindFirstAncestor("FruitSpawnLocations") then
                        Obj:Destroy()
                    end
                end

                -- Destroy isi buah
                local Fruits = Plant:FindFirstChild("Fruits")
                if Fruits then
                    for _, Fruit in ipairs(Fruits:GetChildren()) do
                        for _, Obj in ipairs(Fruit:GetChildren()) do
                            if (Obj:IsA("Part") or Obj:IsA("MeshPart"))
                                and Obj.Name ~= "HarvestPart"
                                and Obj.Name ~= "Base" then
                                Obj:Destroy()
                            end
                        end
                    end
                end
            end
        end
    end


    -- DESTROY DROPPED ITEMS VISUAL
    for _, Item in ipairs(DroppedItems:GetChildren()) do
        
        local Visual = Item:FindFirstChild("Visual")

        if Visual and Visual:IsA("Model") then
            Visual:Destroy()
        end

    end


    task.wait(1)
end
