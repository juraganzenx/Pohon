-- EQUIP ALL FRUIT LOOP

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local TARGETS = {
    "Moon Bloom",
    "Star Fruit"
}

local DELAY = 0.8


local function IsTarget(Name)

    for _, Target in ipairs(TARGETS) do

        if Name == Target then
            return true
        end

    end

    return false
end


local function ClickButton(Button)

    if firesignal then
        firesignal(Button.MouseButton1Click)
    else
        for _, conn in ipairs(getconnections(Button.MouseButton1Click)) do
            conn:Fire()
        end
    end

end


local function EquipAllFruit()

    local BackpackGui = LocalPlayer.PlayerGui:FindFirstChild("BackpackGui")

    if not BackpackGui then
        return
    end

    local GridFrame = BackpackGui.Backpack.Inventory.ScrollingFrame.UIGridFrame

    local Count = 0

    for _, Button in ipairs(GridFrame:GetChildren()) do

        if Button:IsA("TextButton") then

            local ToolName = Button:FindFirstChild("ToolName")

            if ToolName and IsTarget(ToolName.ContentText) then

                Count += 1

                print("Klik:", ToolName.ContentText, "#"..Count)

                ClickButton(Button)

                task.wait(0.1)
            end
        end
    end


    if Count > 0 then
        print("Total item diklik:", Count)
    end
end


--------------------------------------------------
-- LOOP
--------------------------------------------------

while task.wait(DELAY) do

    EquipAllFruit()

end
